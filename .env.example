# ==============================================================
# IRON FORGE — Environment template
# ==============================================================
# Copy to .env and fill in real values. NEVER commit .env.
#   cp .env.example .env
# ==============================================================

# --- Public host (Caddy auto-TLS). Use "localhost" for local demo. ---
N8N_DOMAIN=n8n.example.com
GENERIC_TIMEZONE=America/Chicago

# --- n8n editor login (HTTP basic auth) ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=[REDACTED]
# 32+ char secret; encrypts stored credentials. Generate: openssl rand -hex 24
N8N_ENCRYPTION_KEY=[REDACTED]

# --- n8n's own Postgres (state store; NOT the app DB) ---
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=[REDACTED]

# --- Anthropic (conversation generation) ---
# Current production tier for high-volume per-message SMS generation.
# Swap to claude-opus-4-8 only if a vertical needs deeper reasoning.
CLAUDE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=[REDACTED]   # sk-ant-...

# --- Supabase (application database) ---
SUPABASE_URL=https://[REDACTED].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[REDACTED]   # service_role JWT — server-side only

# --- Twilio (SMS, 10DLC/A2P registered) ---
TWILIO_ACCOUNT_SID=[REDACTED]
TWILIO_AUTH_TOKEN=[REDACTED]

# --- Stripe (payments / Stripe Connect) ---
STRIPE_SECRET_KEY=[REDACTED]   # sk_live_... or sk_test_...
